SV_STREAM_SECRET=generate-a-long-random-string-for-secure-link
SV_API_KEY=generate-a-long-random-admin-api-key
SV_PLAYBACK_KEY=generate-a-long-random-playback-only-key

# Backend Config
SV_PORT=8080
SV_DB_PATH=/data/selvod.db
SV_STORAGE_PATH=/data
SV_MAX_WORKERS=2

# Routing & Edge
# Local: http://localhost:18080 | Prod: https://vod.example.com
SV_BASE_URL=http://localhost:18080
SV_FRONTEND_URL=http://localhost:5173
SV_SERVER_NAME=localhost

# Host Port Mapping
SV_BACKEND_PORT=8080
SV_HTTP_PORT=80
SV_HTTPS_PORT=443
SV_LOCAL_PORT=18080
SV_LOCAL_HTTPS_PORT=18443
SV_TEST_HTTP_PORT=18080
SV_TEST_HTTPS_PORT=18443
